{
  "extends": "../../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "noEmit": false,
    "composite": true,
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "paths": {
      "@q9labsai/chalk-client": ["../client/dist/index.d.ts"],
      "@q9labsai/facehash": ["../../../packages/facehash/src/index.ts"],
      "@q9labsai/facehash/react": ["../../../packages/facehash/src/react.ts"],
      "@q9labsai/chalk-ui/button": ["../../../packages/ui/dist/button.d.ts"],
      "@q9labsai/chalk-ui/reactions": ["../../../packages/ui/dist/reactions.d.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.test.tsx"],
  "references": [{ "path": "../../../packages/facehash" }]

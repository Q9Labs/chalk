{
  "name": "@q9labsai/chalk-client",
  "version": "0.0.85",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Q9Labs/chalk.git",
    "directory": "sdks/typescript/client"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": [
    "./dist/server/server-only.js",
    "./dist/server/server-only.cjs",
    "./dist/webhooks/server-only.js",
    "./dist/webhooks/server-only.cjs"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "telemetry": [
        "./dist/telemetry/index.d.ts"
      ],
      "effect": [
        "./dist/effect.d.ts"
      ],
      "media": [
        "./dist/media/index.d.ts"
      ],
      "sync": [
        "./dist/sync/index.d.ts"
      ],
      "server": [
        "./dist/server/index.d.ts"
      ],
      "webhooks": [
        "./dist/webhooks/index.d.ts"
      ],
      "webhooks/test": [
        "./dist/webhooks/test.d.ts"
      ],
      "*": [
        "./dist/index.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./telemetry": {
      "types": "./dist/telemetry/index.d.ts",
      "react-native": "./dist/telemetry/index.js",
      "import": "./dist/telemetry/index.js",
      "require": "./dist/telemetry/index.js",
      "default": "./dist/telemetry/index.js"
    },
    "./effect": {
      "types": "./dist/effect.d.ts",
      "react-native": "./dist/effect.js",
      "import": "./dist/effect.js",
      "require": "./dist/effect.js",
      "default": "./dist/effect.js"
    },
    "./media": {
      "types": "./dist/media/index.d.ts",
      "react-native": "./dist/media/index.js",
      "import": "./dist/media/index.js",
      "require": "./dist/media/index.js",
      "default": "./dist/media/index.js"
    },
    "./sync": {
      "types": "./dist/sync/index.d.ts",
      "react-native": "./dist/sync/index.js",
      "import": "./dist/sync/index.js",
      "require": "./dist/sync/index.js",
      "default": "./dist/sync/index.js"
    },
    "./server": {
      "workerd": {
        "types": "./dist/server/index.d.ts",
        "default": "./dist/server/index.js"
      },
      "browser": {
        "import": {
          "types": "./dist/server/server-only.d.ts",
          "default": "./dist/server/server-only.js"
        },
        "require": {
          "types": "./dist/server/server-only.d.cts",
          "default": "./dist/server/server-only.cjs"
        },
        "default": "./dist/server/server-only.js"
      },
      "react-native": {
        "import": {
          "types": "./dist/server/server-only.d.ts",
          "default": "./dist/server/server-only.js"
        },
        "require": {
          "types": "./dist/server/server-only.d.cts",
          "default": "./dist/server/server-only.cjs"
        },
        "default": "./dist/server/server-only.js"
      },
      "import": {
        "types": "./dist/server/index.d.ts",
        "default": "./dist/server/index.js"
      },
      "require": {
        "types": "./dist/server/index.d.cts",
        "default": "./dist/server/index.cjs"
      },
      "default": "./dist/server/index.js"
    },
    "./webhooks": {
      "browser": {
        "import": {
          "types": "./dist/webhooks/server-only.d.ts",
          "default": "./dist/webhooks/server-only.js"
        },
        "require": {
          "types": "./dist/webhooks/server-only.d.cts",
          "default": "./dist/webhooks/server-only.cjs"
        },
        "default": "./dist/webhooks/server-only.js"
      },
      "react-native": {
        "import": {
          "types": "./dist/webhooks/server-only.d.ts",
          "default": "./dist/webhooks/server-only.js"
        },
        "require": {
          "types": "./dist/webhooks/server-only.d.cts",
          "default": "./dist/webhooks/server-only.cjs"
        },
        "default": "./dist/webhooks/server-only.js"
      },
      "import": {
        "types": "./dist/webhooks/index.d.ts",
        "default": "./dist/webhooks/index.js"
      },
      "require": {
        "types": "./dist/webhooks/index.d.cts",
        "default": "./dist/webhooks/index.cjs"
      },
      "default": "./dist/webhooks/index.js"
    },
    "./webhooks/test": {
      "browser": {
        "import": {
          "types": "./dist/webhooks/server-only.d.ts",
          "default": "./dist/webhooks/server-only.js"
        },
        "require": {
          "types": "./dist/webhooks/server-only.d.cts",
          "default": "./dist/webhooks/server-only.cjs"
        },
        "default": "./dist/webhooks/server-only.js"
      },
      "react-native": {
        "import": {
          "types": "./dist/webhooks/server-only.d.ts",
          "default": "./dist/webhooks/server-only.js"
        },
        "require": {
          "types": "./dist/webhooks/server-only.d.cts",
          "default": "./dist/webhooks/server-only.cjs"
        },
        "default": "./dist/webhooks/server-only.js"
      },
      "import": {
        "types": "./dist/webhooks/test.d.ts",
        "default": "./dist/webhooks/test.js"
      },
      "require": {
        "types": "./dist/webhooks/test.d.cts",
        "default": "./dist/webhooks/test.cjs"
      },
      "default": "./dist/webhooks/test.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "pnpm run generate:webhooks && rm -rf ./dist && tsup ./src/index.ts ./src/telemetry/index.ts ./src/effect.ts ./src/media/index.ts ./src/sync/index.ts --format esm --out-dir ./dist --platform browser --external effect && tsup ./src/webhooks/index.ts ./src/webhooks/test.ts ./src/webhooks/server-only.ts --format esm,cjs --out-dir ./dist/webhooks --platform neutral && tsup ./src/server/index.ts ./src/server/server-only.ts --format esm,cjs --out-dir ./dist/server --platform node && pnpm run build:types && pnpm run build:webhooks:cjs-types",
    "build:types": "rm -f tsconfig.tsbuildinfo && tsc --build tsconfig.json",
    "build:webhooks:cjs-types": "node ./scripts/generate-webhook-cjs-types.mjs",
    "dev": "tsup ./src/index.ts ./src/telemetry/index.ts ./src/effect.ts ./src/media/index.ts ./src/sync/index.ts --format esm --out-dir ./dist --platform browser --external effect --watch",
    "generate:webhooks": "node ./scripts/generate-webhook-contract.mjs",
    "check:webhooks-generated": "node ./scripts/generate-webhook-contract.mjs --check",
    "test": "pnpm exec vitest run",
    "test:webhooks-package": "pnpm run build && node ./scripts/check-webhook-package.mjs",
    "test:server-package": "pnpm run build && node ./scripts/check-server-package.mjs",
    "test:sync-browser": "pnpm run build && node ./scripts/real-browser-sync.mjs",
    "test:sync-node-restart": "pnpm run build && node ./scripts/real-node-restart-sync.mjs",
    "check-types": "tsc --noEmit",
    "lint": "pnpm exec oxfmt --check . && tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "effect": "4.0.0-beta.94"
  },
  "devDependencies": {
    "esbuild": "0.28.1",
    "playwright": "^1.57.0"
  },
  "engines": {
    "node": ">=22"
  }
}

{
	"$schema": "https://turborepo.com/schema.json",
	"ui": "tui",
	"globalEnv": ["NODE_ENV", "CI"],
	"concurrency": "15",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"inputs": [
				"$TURBO_DEFAULT$",
				".env*",
				"!**/*.md",
				"!**/*.test.*",
				"!**/*.spec.*"
			],
			"outputs": ["dist/**", ".output/**"],
			"env": ["DATABASE_URL", "API_URL", "CLOUDFLARE_API_TOKEN", "VITE_*"]
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"test": {
			"inputs": ["$TURBO_DEFAULT$", "!**/*.md"],
			"outputs": ["coverage/**"],
			"env": ["CI", "NODE_ENV"]
		},
		"check-types": {
			"dependsOn": ["^build"],
			"inputs": ["**/*.ts", "**/*.tsx", "tsconfig.json"],
			"outputs": []
		},
		"lint": {
			"dependsOn": ["^build"],
			"inputs": ["$TURBO_DEFAULT$", "!**/*.md"],
			"outputs": []
		},
		"clean": {
			"cache": false
		},
		"generate:types": {
			"inputs": ["../../apps/api/openapi.yaml"],
			"outputs": ["src/generated/api-types.ts"]
		}
	}
}

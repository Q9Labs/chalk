{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "node ../../scripts/dev-log.mjs dev:raw",
    "dev:raw": "node scripts/local-dev.mjs",
    "dev:vite": "vite dev --host 127.0.0.1 --port 3070",
    "build": "pnpm run sync:public && vite build && node scripts/prepare-pages-spa.mjs",
    "sync:public": "pnpm exec tsx scripts/sync-public-assets.ts",
    "preview": "vite preview",
    "test": "pnpm exec vitest run --config ./vitest.config.ts",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@cloudflare/vite-plugin": "^1.43.0",
    "@q9labsai/chalk-client": "workspace:^",
    "@q9labsai/chalk-react": "workspace:^",
    "@tanstack/react-router": "1.170.16",
    "@tanstack/react-start": "1.168.26",
    "@tanstack/router-plugin": "1.168.18",
    "nitro": "latest",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "unenv": "^1.10.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260701.1",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  }
}

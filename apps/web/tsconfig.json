{
  "extends": "../../tsconfig.json",
  "include": ["**/*.ts", "**/*.tsx", "**/*.mdx"],
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client", "@cloudflare/workers-types"],

    /* Bundler mode */
    "verbatimModuleSyntax": false,

    /* Linting */
    "noUncheckedSideEffectImports": true,

    /* Path aliases - must redeclare since paths don't merge */
    "paths": {
      "@/*": ["./src/*"],
      "@q9labs/chalk-ui": ["../../packages/ui/src/index.ts"],
      "@q9labs/chalk-ui/button": ["../../packages/ui/src/button.tsx"],
      "@q9labs/chalk-ui/utils": ["../../packages/ui/src/lib/utils.ts"]
    }
  }
}

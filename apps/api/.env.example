# Cloudflare RealtimeKit
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_APP_ID=your_realtimekit_app_id
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token

# Database
DATABASE_URL=postgres://user:password@localhost:5432/chalk?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SIGNING_KEY=your-secure-jwt-signing-key
JWT_EXPIRY_MINUTES=60

# Server
PORT=8080
ENV=development

# Demo Mode (set to true to enable /api/v1/demo/join endpoint)
CHALK_ENABLE_DEMO=true

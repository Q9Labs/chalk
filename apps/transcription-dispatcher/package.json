    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-ssm": "3.1085.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "esbuild": "0.28.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=22"
  }
}

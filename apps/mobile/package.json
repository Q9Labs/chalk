{
  "name": "@q9labsai/chalk-mobile",
  "private": true,
  "license": "MIT",
  "main": "./index.ts",
  "scripts": {
    "start": "expo start --clear",
    "start:ios-sim": "node ./scripts/start-ios-sim-dev-client.mjs",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "prebuild:android": "expo prebuild --platform android --no-install",
    "prebuild:android:production": "CHALK_APP_VARIANT=production expo prebuild --platform android --no-install",
    "prebuild:ios": "expo prebuild --platform ios --no-install",
    "prebuild:ios:production": "CHALK_APP_VARIANT=production expo prebuild --platform ios --clean --no-install",
    "build": "expo export --platform ios --output-dir dist/ios && expo export --platform android --output-dir dist/android",
    "build:android:apk:release": "cd android && ./gradlew assembleRelease",
    "build:android:apk:release:production": "pnpm exec tsx ./scripts/run-with-production-mobile-env.ts -- pnpm run build:android:apk:release",
    "build:android:release": "cd android && ./gradlew bundleRelease",
    "build:android:release:production": "pnpm exec tsx ./scripts/run-with-production-mobile-env.ts -- pnpm run build:android:release",
    "with:production-release-env": "pnpm exec tsx ./scripts/run-with-production-mobile-env.ts --",
    "verify:production-host-key": "pnpm exec tsx ./scripts/verify-production-mobile-host-key.ts",
    "check-types": "tsc --noEmit",
    "lint": "pnpm exec oxfmt --check . && tsc --noEmit",
    "test": "pnpm exec vitest run"
  },
  "dependencies": {
    "@babel/runtime": "^7.28.4",
    "@cloudflare/react-native-webrtc": "~125.0.3",
    "@cloudflare/realtimekit-react-native": "^0.3.1",
    "@expo/vector-icons": "^15.0.2",
    "@hugeicons/core-free-icons": "^4.0.0",
    "@hugeicons/react-native": "^1.0.13",
    "@q9labsai/chalk-react-native": "workspace:^",
    "expo": "^55.0.6",
    "expo-audio": "~55.0.9",
    "expo-clipboard": "~55.0.9",
    "expo-dev-client": "^55.0.16",
    "expo-file-system": "~55.0.12",
    "expo-linking": "^55.0.7",
    "expo-secure-store": "~55.0.8",
    "expo-splash-screen": "~55.0.10",
    "expo-sqlite": "~55.0.11",
    "expo-status-bar": "~55.0.4",
    "react": "19.2.7",
    "react-native": "0.83.2",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-svg": "^15.15.3"
  },
  "devDependencies": {
    "@babel/core": "^7.28.4",
    "@types/node": "^24.10.1",
    "@types/react": "~19.2.10",
    "babel-preset-expo": "^55.0.11",
    "typescript": "^5.7.2"
  }
}

#!/usr/bin/env bash
set -euo pipefail

caller_directory="${PWD}"

if [[ "${1:-}" == "replay" && -n "${2:-}" && "${2}" != /* ]]; then
  replay_path="${caller_directory}/${2}"
  shift 2
  set -- replay "${replay_path}" "$@"
fi

cd "$(dirname "$0")/.."
exec env MIX_ENV=test mix run --no-start scripts/sync_breaker_v2.exs -- "$@"

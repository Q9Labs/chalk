{
  "name": "chalk",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/web",
    "apps/docs"
  ],
  "type": "module",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "dev:web:pages": "bun run --cwd apps/web dev:pages",
    "test": "bun run test:scripts && turbo test",
    "lint": "turbo lint",
    "check-types": "turbo check-types",
    "clean": "turbo clean && rm -rf node_modules",
    "generate": "turbo run generate:types",
    "code:index": "bun run ./scripts/code-index.ts index",
    "code:search": "bun run ./scripts/code-index.ts search",
    "code:stats": "bun run ./scripts/code-index.ts stats",
    "test:scripts": "bun test ./scripts"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "^0.18.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.26",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.17.1",
    "@types/bun": "latest",
    "oxfmt": "^0.36.0",
    "turbo": "^2.7.2",
    "typescript": "^5.7.2",
    "wrangler": "^4.54.0",
    "yaml": "^2.8.2"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "bun@1.1.42"
}

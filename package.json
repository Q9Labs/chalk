{
	"name": "chalk",
	"private": true,
	"type": "module",
	"workspaces": [
		"packages/*",
		"packages/sdk-react-native/example",
		"apps/web",
		"apps/mobile",
		"apps/mobile2",
		"apps/docs"
	],
	"scripts": {
		"build": "turbo build",
		"dev": "turbo dev",
		"test": "turbo test",
		"lint": "turbo lint",
		"check-types": "turbo check-types",
		"clean": "turbo clean && rm -rf node_modules",
		"generate": "turbo run generate:types",
		"mobile:ios": "cd apps/mobile2 && npx expo run:ios",
		"mobile:android": "cd apps/mobile2 && npx expo run:android",
		"mobile:start": "cd apps/mobile2 && npx expo start --dev-client --clear",
		"mobile:prebuild": "cd apps/mobile2 && npx expo prebuild --clean",
		"mobile:verify": "bun run scripts/verify-mobile.ts"
	},
	"devDependencies": {
		"@cloudflare/vite-plugin": "^1.17.1",
		"@types/bun": "latest",
		"turbo": "^2.7.2",
		"typescript": "^5.7.2",
		"wrangler": "^4.54.0",
		"yaml": "^2.8.2"
	},
	"engines": {
		"node": ">=20"
	},
	"overrides": {
		"react-native-reanimated": "~3.19.5"
	},
	"packageManager": "bun@1.1.42",
	"dependencies": {
		"@excalidraw/excalidraw": "^0.18.0",
		"clsx": "^2.1.1",
		"framer-motion": "^12.23.26",
		"tailwind-merge": "^3.4.0"
	}
}

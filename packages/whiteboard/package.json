{
  "name": "@q9labsai/chalk-whiteboard",
  "version": "0.0.85",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Q9Labs/chalk.git",
    "directory": "packages/whiteboard"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "react": [
        "./dist/react/index.d.ts"
      ],
      "collab": [
        "./dist/collab/index.d.ts"
      ],
      "*": [
        "./dist/index.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    },
    "./collab": {
      "types": "./dist/collab/index.d.ts",
      "import": "./dist/collab/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "rm -rf ./dist && tsup ./src/index.ts ./src/react/index.ts ./src/collab/index.ts --format esm --out-dir ./dist --platform browser --splitting --external react --external react-dom --external @excalidraw/excalidraw && pnpm run build:types",
    "build:types": "rm -f tsconfig.tsbuildinfo && tsc --emitDeclarationOnly --declaration --outDir dist",
    "dev": "tsup ./src/index.ts ./src/react/index.ts ./src/collab/index.ts --format esm --out-dir ./dist --platform browser --splitting --external react --external react-dom --external @excalidraw/excalidraw --watch",
    "test": "pnpm exec vitest run",
    "check-types": "tsc --noEmit",
    "lint": "pnpm exec oxfmt --check . && tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "^0.18.1"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.0.0",
    "happy-dom": "^20.0.11",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "typescript": "^5.7.2"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  }
}

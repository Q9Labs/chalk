{
  "name": "@q9labs/chalk-react",
  "version": "0.0.14",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./styles.css": "./dist/styles/bundled.css",
    "./styles/bundled.css": "./dist/styles/bundled.css",
    "./styles/base.css": "./dist/styles/base.css",
    "./styles/variables.css": "./dist/styles/variables.css",
    "./styles/animations.css": "./dist/styles/animations.css",
    "./styles/*": "./dist/styles/*",
    "./dist/styles/bundled.css": "./dist/styles/bundled.css",
    "./dist/styles/base.css": "./dist/styles/base.css",
    "./dist/styles/variables.css": "./dist/styles/variables.css",
    "./dist/styles/animations.css": "./dist/styles/animations.css",
    "./dist/styles/*": "./dist/styles/*"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target browser --external react --external react-dom --external @chalk/core --external @q9labs/chalk-whiteboard && bun run build:types && bun run build:styles",
    "build:styles": "mkdir -p ./dist/styles && cp ./src/styles/*.css ./dist/styles/",
    "build:types": "tsc --emitDeclarationOnly --declaration --outDir dist",
    "dev": "bun build ./src/index.ts --outdir ./dist --target browser --external react --external react-dom --external @chalk/core --watch",
    "test": "bun test --preload ./src/__tests__/setup.ts",
    "check-types": "tsc --noEmit",
    "lint": "echo 'No linter configured yet'",
    "clean": "rm -rf dist",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@cloudflare/realtimekit": "^1.2.2",
    "@cloudflare/realtimekit-react": "^1.2.2",
    "@q9labs/chalk-core": "^0.0.14",
    "clsx": "^2.1.1",
    "lucide-react": "^0.562.0",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.1.3",
    "@storybook/addon-a11y": "8.6.14",
    "@storybook/addon-docs": "8.6.14",
    "@storybook/addon-essentials": "8.6.14",
    "@storybook/addon-interactions": "8.6.14",
    "@storybook/addon-links": "8.6.14",
    "@storybook/addon-onboarding": "8.6.14",
    "@storybook/blocks": "8.6.14",
    "@storybook/react": "8.6.14",
    "@storybook/react-vite": "8.6.14",
    "@storybook/test": "8.6.14",
    "@tailwindcss/vite": "^4.1.18",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "latest",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/browser-playwright": "^4.0.16",
    "@vitest/coverage-v8": "^4.0.16",
    "autoprefixer": "^10.4.23",
    "happy-dom": "^20.0.11",
    "jsdom": "^27.4.0",
    "playwright": "^1.57.0",
    "postcss": "^8.5.6",
    "storybook": "8.6.14",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.7.2",
    "vitest": "^4.0.16"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "typescript": "^5",
    "@q9labs/chalk-whiteboard": "^0.0.14"
  },
  "peerDependenciesMeta": {
    "@q9labs/chalk-whiteboard": {
      "optional": true
    }
  }
}

{
	"name": "@q9labs/chalk-react",
	"version": "0.0.5",
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"publishConfig": {
		"registry": "https://npm.pkg.github.com/"
	},
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "bun build ./src/index.ts --outdir ./dist --target browser --external react --external react-dom --external @chalk/core && bun run build:types",
		"build:types": "tsc --emitDeclarationOnly --declaration --outDir dist",
		"dev": "bun build ./src/index.ts --outdir ./dist --target browser --external react --external react-dom --external @chalk/core --watch",
		"test": "bun test",
		"check-types": "tsc --noEmit",
		"lint": "echo 'No linter configured yet'",
		"clean": "rm -rf dist"
	},
	"dependencies": {
		"@cloudflare/realtimekit": "^1.2.2",
		"@cloudflare/realtimekit-react": "^1.2.2",
		"@q9labs/chalk-core": "workspace:*",
		"clsx": "^2.1.1",
		"lucide-react": "^0.562.0",
		"tailwind-merge": "^3.4.0"
	},
	"devDependencies": {
		"@tailwindcss/vite": "^4.1.18",
		"@types/bun": "latest",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"autoprefixer": "^10.4.23",
		"postcss": "^8.5.6",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.7.2"
	},
	"peerDependencies": {
		"react": "^18.0.0 || ^19.0.0",
		"react-dom": "^18.0.0 || ^19.0.0",
		"typescript": "^5"
	}
}

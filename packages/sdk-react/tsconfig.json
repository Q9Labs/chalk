{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "noEmit": false,
    "composite": true,
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "paths": {
      "@q9labs/facehash": ["../facehash/src/index.ts"],
      "@q9labs/facehash/react": ["../facehash/src/react.ts"],
      "@q9labs/chalk-ui/button": ["../ui/dist/button.d.ts"],
      "@q9labs/chalk-ui/reactions": ["../ui/dist/reactions.d.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.test.tsx"],
  "references": [{ "path": "../facehash" }]
}

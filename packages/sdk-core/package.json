{
  "name": "@q9labs/chalk-core",
  "version": "0.0.80",
  "repository": {
    "type": "git",
    "url": "https://github.com/Q9Labs/chalk.git",
    "directory": "packages/sdk-core"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/"
  },
  "scripts": {
    "build": "tsup ./src/index.ts --format esm --out-dir ./dist --platform browser --external @cloudflare/realtimekit && pnpm run build:types",
    "build:types": "tsc --project tsconfig.json",
    "dev": "tsup ./src/index.ts --format esm --out-dir ./dist --platform browser --external @cloudflare/realtimekit --watch",
    "test": "pnpm exec vitest run ./src/__tests__",
    "test:mutation:participant-avatar-recipe": "../../apps/web/node_modules/.bin/stryker run stryker.participant-avatar.config.json",
    "check-types": "tsc --noEmit",
    "lint": "echo 'No linter configured yet'",
    "clean": "rm -rf dist",
    "generate:types": "openapi-typescript ../../apps/api/openapi.yaml -o src/generated/api-types.ts"
  },
  "dependencies": {
    "@cloudflare/realtimekit": "^1.2.4",
    "@cloudflare/realtimekit-virtual-background": "^0.0.2",
    "@effect/schema": "^0.75.5",
    "@q9labs/chalk-whiteboard": "workspace:^",
    "effect": "^3.11.9"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "openapi-typescript": "^7.0.0",
    "typescript": "^5.7.2",
    "@types/node": "^24.10.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}

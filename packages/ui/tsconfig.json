{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@q9labs/chalk-core": ["../sdk-core/src/index.ts"],
      "@q9labs/chalk-react": ["../sdk-react/src/index.ts"],
      "@q9labs/chalk-react-native": ["../sdk-react-native/src/index.ts"],
      "@q9labs/chalk-ui": ["./src/index.ts"]
    },
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "outDir": "./dist",
    "rootDir": "./src"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.test.tsx"]
}

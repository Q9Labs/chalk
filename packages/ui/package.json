{
	"name": "@q9labs/chalk-ui",
	"version": "0.0.14",
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"publishConfig": {
		"registry": "https://npm.pkg.github.com/"
	},
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "bun build ./src/index.ts --outdir ./dist --target node --external react --external react-native --external @chalk/core && bun run build:types",
		"build:types": "tsc --emitDeclarationOnly --declaration --outDir dist",
		"dev": "bun build ./src/index.ts --outdir ./dist --target node --external react --external react-native --external @chalk/core --watch",
		"test": "bun test",
		"check-types": "tsc --noEmit",
		"lint": "echo 'No linter configured yet'",
		"clean": "rm -rf dist"
	},
	"dependencies": {
		"@base-ui/react": "^1.0.0",
		"@q9labs/chalk-core": "workspace:*",
		"@hugeicons/core-free-icons": "^3.1.0",
		"@hugeicons/react": "^1.1.4",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"tailwind-merge": "^3.4.0"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"@types/react": "^19.0.0",
		"typescript": "^5.7.2"
	},
	"peerDependencies": {
		"react": "^18.0.0 || ^19.0.0",
		"react-native": ">=0.70.0",
		"typescript": "^5"
	}
}

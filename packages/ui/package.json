{
  "name": "@q9labs/chalk-ui",
  "version": "0.0.85",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Q9Labs/chalk.git",
    "directory": "packages/ui"
  },
  "style": "./dist/styles.css",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/"
  },
  "scripts": {
    "build": "tsup ./src/index.ts --format esm --out-dir ./dist --platform node --external react --external @chalk/core && pnpm run build:types && pnpm run build:css",
    "build:types": "rm -f tsconfig.tsbuildinfo && tsc --emitDeclarationOnly --declaration --outDir dist",
    "build:css": "mkdir -p ./dist && cp ./src/styles/index.css ./dist/styles.css",
    "dev": "pnpm run build:css && tsup ./src/index.ts --format esm --out-dir ./dist --platform node --external react --external @chalk/core --watch",
    "test": "pnpm exec vitest run",
    "check-types": "tsc --noEmit",
    "lint": "pnpm exec oxfmt --check . && tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@base-ui/react": "^1.0.0",
    "@q9labs/chalk-core": "workspace:^",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.18",
    "@types/node": "^24.10.1",
    "@types/react": "^19.0.0",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.7.2"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  }
}

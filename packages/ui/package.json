{
	"name": "@q9labs/chalk-ui",
	"version": "0.0.50",
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"style": "./dist/styles.css",
	"repository": {
		"type": "git",
		"url": "https://github.com/Q9Labs/chalk.git",
		"directory": "packages/ui"
	},
	"publishConfig": {
		"registry": "https://npm.pkg.github.com/"
	},
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		},
		"./styles.css": "./dist/styles.css"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "bun build ./src/index.ts --outdir ./dist --target node --external react --external react-native --external @chalk/core && bun run build:types && bun run build:css",
		"build:types": "tsc --emitDeclarationOnly --declaration --outDir dist",
		"build:css": "mkdir -p ./dist && cp ./src/styles/index.css ./dist/styles.css",
		"dev": "bun run build:css && bun build ./src/index.ts --outdir ./dist --target node --external react --external react-native --external @chalk/core --watch",
		"test": "echo 'No tests configured yet'",
		"check-types": "tsc --noEmit",
		"lint": "echo 'No linter configured yet'",
		"clean": "rm -rf dist"
	},
	"dependencies": {
		"@base-ui/react": "^1.0.0",
		"@q9labs/chalk-core": "workspace:^",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"lucide-react": "^0.468.0",
		"tailwind-merge": "^3.4.0"
	},
	"devDependencies": {
		"@tailwindcss/cli": "^4.1.18",
		"@types/bun": "latest",
		"@types/react": "^19.0.0",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.7.2"
	},
	"peerDependencies": {
		"react": "^18.0.0 || ^19.0.0"
	},
	"peerDependenciesMeta": {
		"react-native": {
			"optional": true
		}
	}
}

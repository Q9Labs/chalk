{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"outDir": "./dist",
		"rootDir": "./src",
		"declaration": true,
		"declarationMap": true,
		"noEmit": false,
		"composite": true,
		"lib": ["ESNext"],
		"jsx": "react-jsx",
		"types": ["react-native"]
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.test.tsx"],
	"references": [{ "path": "../sdk-core" }]
}

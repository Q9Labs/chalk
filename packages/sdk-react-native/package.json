{
	"name": "@chalk/react-native",
	"version": "0.0.1",
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "bun build ./src/index.ts --outdir ./dist --target node --external react --external react-native --external @chalk/core && bun run build:types",
		"build:types": "tsc --emitDeclarationOnly --declaration --outDir dist",
		"dev": "bun build ./src/index.ts --outdir ./dist --target node --external react --external react-native --external @chalk/core --watch",
		"test": "bun test",
		"check-types": "tsc --noEmit",
		"lint": "echo 'No linter configured yet'",
		"clean": "rm -rf dist"
	},
	"dependencies": {
		"@chalk/core": "workspace:*"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"@types/react": "^19.0.0",
		"typescript": "^5.7.2"
	},
	"peerDependencies": {
		"react": "^18.0.0 || ^19.0.0",
		"react-native": ">=0.70.0",
		"typescript": "^5"
	}
}

{
	"name": "@q9labs/chalk-react-native",
	"version": "0.0.35",
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"repository": {
		"type": "git",
		"url": "https://github.com/Q9Labs/chalk.git",
		"directory": "packages/sdk-react-native"
	},
	"publishConfig": {
		"registry": "https://npm.pkg.github.com/"
	},
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "bun build ./src/index.ts --outdir ./dist --target node --external react --external react-native --external @cloudflare/react-native-webrtc --external @chalk/core && bun run build:types",
		"build:types": "tsc --emitDeclarationOnly --declaration --outDir dist",
		"dev": "bun build ./src/index.ts --outdir ./dist --target node --external react --external react-native --external @cloudflare/react-native-webrtc --external @chalk/core --watch",
		"test": "bun test",
		"check-types": "tsc --noEmit",
		"lint": "echo 'No linter configured yet'",
		"clean": "rm -rf dist"
	},
	"dependencies": {
		"@q9labs/chalk-core": "workspace:^"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"@types/react": "^19.0.0",
		"typescript": "^5.7.2"
	},
	"peerDependencies": {
		"@cloudflare/realtimekit-react-native": ">=0.3.0",
		"react": "^18.0.0 || ^19.0.0",
		"react-native": ">=0.70.0",
		"@cloudflare/react-native-webrtc": ">=125.0.0",
		"typescript": "^5"
	}
}

# Copy to .private/chalk-terraform.env and replace each placeholder with a
# 1Password secret reference. Keep the copied file ignored/private.
#
# Format:
#   TF_VAR_name=op://<vault>/<item>/<field>
#
# Terraform accepts JSON strings for complex list/map values through TF_VAR_*.
# Use Terraform remote state for state files. Do not put state, plans, account
# identifiers, or resolved secret values in this file.

# Provider and routing inputs.
TF_VAR_aws_region=op://<vault>/<item>/aws_region
TF_VAR_cloudflare_zone_name=op://<vault>/<item>/cloudflare_zone_name
TF_VAR_api_subdomain=op://<vault>/<item>/api_subdomain
TF_VAR_ws_subdomain=op://<vault>/<item>/ws_subdomain
TF_VAR_cloudflare_proxy_enabled=op://<vault>/<item>/cloudflare_proxy_enabled
TF_VAR_manage_dns_records=op://<vault>/<item>/manage_dns_records

# Cloudflare and R2.
TF_VAR_cloudflare_account_id=op://<vault>/<item>/cloudflare_account_id
TF_VAR_cloudflare_api_token=op://<vault>/<item>/cloudflare_api_token
TF_VAR_r2_access_key_id=op://<vault>/<item>/r2_access_key_id
TF_VAR_r2_secret_access_key=op://<vault>/<item>/r2_secret_access_key

# Upstash.
TF_VAR_upstash_email=op://<vault>/<item>/upstash_email
TF_VAR_upstash_api_key=op://<vault>/<item>/upstash_api_key
TF_VAR_upstash_region=op://<vault>/<item>/upstash_region
TF_VAR_upstash_database_name=op://<vault>/<item>/upstash_database_name
TF_VAR_upstash_tls=op://<vault>/<item>/upstash_tls
TF_VAR_upstash_eviction=op://<vault>/<item>/upstash_eviction

# PlanetScale.
TF_VAR_planetscale_service_token_id=op://<vault>/<item>/planetscale_service_token_id
TF_VAR_planetscale_service_token=op://<vault>/<item>/planetscale_service_token
TF_VAR_planetscale_organization=op://<vault>/<item>/planetscale_organization
TF_VAR_planetscale_database=op://<vault>/<item>/planetscale_database
TF_VAR_planetscale_database_name=op://<vault>/<item>/planetscale_database_name
TF_VAR_planetscale_branch=op://<vault>/<item>/planetscale_branch

# Realtime and runtime secrets.
TF_VAR_cloudflare_app_id=op://<vault>/<item>/cloudflare_app_id
TF_VAR_cloudflare_app_token=op://<vault>/<item>/cloudflare_app_token
TF_VAR_post_meeting_cloudflare_api_token=op://<vault>/<item>/post_meeting_cloudflare_api_token
TF_VAR_post_meeting_cloudflare_worker_url=op://<vault>/<item>/post_meeting_cloudflare_worker_url
TF_VAR_post_meeting_cloudflare_worker_dispatch_secret=op://<vault>/<item>/post_meeting_cloudflare_worker_dispatch_secret
TF_VAR_post_meeting_cloudflare_worker_callback_secret=op://<vault>/<item>/post_meeting_cloudflare_worker_callback_secret
TF_VAR_jwt_signing_key=op://<vault>/<item>/jwt_signing_key
TF_VAR_admin_secret=op://<vault>/<item>/admin_secret
TF_VAR_auth_link_signing_key=op://<vault>/<item>/auth_link_signing_key
TF_VAR_resend_api_key=op://<vault>/<item>/resend_api_key
TF_VAR_resend_from_email=op://<vault>/<item>/resend_from_email

# App URLs and auth.
TF_VAR_internal_app_url=op://<vault>/<item>/internal_app_url
TF_VAR_internal_app_urls=op://<vault>/<item>/internal_app_urls
TF_VAR_auth_cookie_domain=op://<vault>/<item>/auth_cookie_domain

# Observability and release metadata.
TF_VAR_axiom_token=op://<vault>/<item>/axiom_token
TF_VAR_axiom_dataset=op://<vault>/<item>/axiom_dataset
TF_VAR_axiom_traces_dataset=op://<vault>/<item>/axiom_traces_dataset
TF_VAR_github_token=op://<vault>/<item>/github_token
TF_VAR_github_owner=op://<vault>/<item>/github_owner
TF_VAR_github_repo=op://<vault>/<item>/github_repo
TF_VAR_openrouter_api_key=op://<vault>/<item>/openrouter_api_key
TF_VAR_groq_api_key=op://<vault>/<item>/groq_api_key
TF_VAR_cloudflare_webhook_secret=op://<vault>/<item>/cloudflare_webhook_secret

# Ops notifications.
TF_VAR_ops_ingest_token=op://<vault>/<item>/ops_ingest_token
TF_VAR_ops_whatsapp_enabled=op://<vault>/<item>/ops_whatsapp_enabled
TF_VAR_ops_twilio_account_sid=op://<vault>/<item>/ops_twilio_account_sid
TF_VAR_ops_twilio_auth_token=op://<vault>/<item>/ops_twilio_auth_token
TF_VAR_ops_twilio_whatsapp_from=op://<vault>/<item>/ops_twilio_whatsapp_from
TF_VAR_ops_whatsapp_to_critical=op://<vault>/<item>/ops_whatsapp_to_critical
TF_VAR_ops_whatsapp_to_major=op://<vault>/<item>/ops_whatsapp_to_major
TF_VAR_ops_public_status_base_url=op://<vault>/<item>/ops_public_status_base_url

# Compute and runtime shape.
TF_VAR_admin_allowed_ips=op://<vault>/<item>/admin_allowed_ips
TF_VAR_db_max_conns=op://<vault>/<item>/db_max_conns
TF_VAR_db_min_conns=op://<vault>/<item>/db_min_conns
TF_VAR_ssm_parameter_path=op://<vault>/<item>/ssm_parameter_path
TF_VAR_instance_type=op://<vault>/<item>/instance_type
TF_VAR_alert_actions=op://<vault>/<item>/alert_actions_json
TF_VAR_ssh_ingress_cidrs=op://<vault>/<item>/ssh_ingress_cidrs_json

# Whisper worker toggles.
TF_VAR_whisper_enabled=op://<vault>/<item>/whisper_enabled
TF_VAR_whisper_instance_type=op://<vault>/<item>/whisper_instance_type
TF_VAR_whisper_use_spot=op://<vault>/<item>/whisper_use_spot
TF_VAR_whisper_ssm_parameter_path=op://<vault>/<item>/whisper_ssm_parameter_path
TF_VAR_whisper_log_level=op://<vault>/<item>/whisper_log_level
TF_VAR_whisper_device=op://<vault>/<item>/whisper_device
TF_VAR_whisper_compute_type=op://<vault>/<item>/whisper_compute_type
TF_VAR_whisper_cpu_threads=op://<vault>/<item>/whisper_cpu_threads
TF_VAR_whisper_gpu_metrics_enabled=op://<vault>/<item>/whisper_gpu_metrics_enabled

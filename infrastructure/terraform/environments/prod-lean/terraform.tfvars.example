ws_subdomain                  = "chalk-ws"
cloudflare_proxy_enabled      = false

cloudflare_account_id         = ""
cloudflare_api_token          = ""
r2_access_key_id              = ""
r2_secret_access_key          = ""

upstash_email                 = ""

# Render to /run/chalk/env/sync.env with mode 0600. This contract intentionally
# leaves production boot checks enabled.
PORT=4100
CHALK_SYNC_BIND_IP=0.0.0.0
CHALK_DATABASE_URL=__SECRET_PLANETSCALE_DIRECT_URL_WITH_SSLMODE_VERIFY_FULL__
CHALK_SYNC_DATABASE_POOL_SIZE=2
CHALK_SYNC_TOKEN_ISSUER=https://api.chalkmeet.com
CHALK_SYNC_TOKEN_AUDIENCE=chalk-sync
CHALK_SYNC_TOKEN_PUBLIC_KEYS=__SECRET_JSON_KEYRING__
CHALK_SYNC_MAX_WAL_LAG_BYTES=16777216
CHALK_SYNC_PROVIDER_BRIDGE_URL=https://chalk-api:8443
CHALK_SYNC_PROVIDER_BRIDGE_CERTFILE=/run/chalk/provider-bridge/client.crt
CHALK_SYNC_PROVIDER_BRIDGE_KEYFILE=/run/chalk/provider-bridge/client.key
CHALK_SYNC_PROVIDER_BRIDGE_CAFILE=/run/chalk/provider-bridge/server-ca.crt
# Optional: CHALK_SYNC_OTLP_ENDPOINT=https://managed-collector.example/v1

# Render to /run/chalk/env/api.env with mode 0600. Values marked __SECRET__ come
# from the production SSM namespace and must never enter the release manifest.
CHALK_API_ADDR=0.0.0.0:8080
CHALK_API_CORS_ALLOWED_ORIGINS=https://chalkmeet.com
CHALK_API_ENV=production
CHALK_API_TRUSTED_PROXY_CIDRS=10.89.0.0/24
CHALK_API_LOG_FORMAT=json
CHALK_API_LOG_LEVEL=info
CHALK_API_OPERATION_LOGS=true
CHALK_API_REQUEST_LOGS=errors
CHALK_API_SERVICE=chalk-api
CHALK_API_VERSION=__RELEASE_ID__
# Optional: CHALK_API_OTLP_ENDPOINT=https://managed-collector.example/v1
CHALK_DATABASE_URL=__SECRET_PLANETSCALE_PGBOUNCER_URL_WITH_SSLMODE_VERIFY_FULL__
CHALK_DATABASE_MAX_CONNS=10
CHALK_DATABASE_MIN_CONNS=2
CHALK_REDIS_URL=redis://redis:6379/0
CHALK_SYNC_TOKEN_ISSUER=https://api.chalkmeet.com
CHALK_SYNC_TOKEN_AUDIENCE=chalk-sync
CHALK_SYNC_TOKEN_KEY_ID=__SECRET__
CHALK_SYNC_TOKEN_PRIVATE_KEY=__SECRET__
CHALK_MEDIA_TOKEN_VERIFICATION_KEYS=__SECRET__
CHALK_PROVIDER_BRIDGE_ADDRESS=0.0.0.0:8443
CHALK_PROVIDER_BRIDGE_SERVER_CERT_FILE=/run/chalk/provider-bridge/server.crt
CHALK_PROVIDER_BRIDGE_SERVER_KEY_FILE=/run/chalk/provider-bridge/server.key
CHALK_PROVIDER_BRIDGE_CLIENT_CA_FILE=/run/chalk/provider-bridge/client-ca.crt
CHALK_PROVIDER_BRIDGE_SPIFFE_TRUST_DOMAIN=chalkmeet.com
CHALK_CLOUDFLARE_ACCOUNT_ID=__SECRET__
CHALK_CLOUDFLARE_API_TOKEN=__SECRET__
CHALK_CLOUDFLARE_REALTIME_APP_ID=__SECRET__
CHALK_CLOUDFLARE_REALTIME_APP_SECRET=__SECRET__
# Optional for a RealtimeKit tenant: CHALK_CLOUDFLARE_RTK_APP_ID and
# CHALK_CLOUDFLARE_RTK_TOKEN_ORG_ID.
CHALK_INTEGRATIONS_ENABLED=false
CHALK_TRANSCRIPTION_ENABLED=false
# Composio, transcription dispatcher, and R2 credentials are required only
# when their matching capability flag is true.
# Google OAuth and Resend credentials are optional for the SDK launch profile.
CHALK_GOOGLE_OAUTH_REDIRECT_URL=https://api.chalkmeet.com/v1/auth/google/callback
CHALK_WEBHOOK_ENCRYPTION_KEY=__SECRET_BASE64_32_BYTES__

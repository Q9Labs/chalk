#!/usr/bin/env bash
set -euo pipefail

managed_root="$(cd "$(dirname "$0")/.." && pwd)"
repo_root="$(cd "${managed_root}/../.." && pwd)"
cloudflared_image="docker.io/cloudflare/cloudflared@sha256:5e49861633763e8933475477c20bae6039ed47f32c1d267a34babc347f28f0df"
redis_image="docker.io/library/redis@sha256:82db05459fb850cc3fe2bfa510a054323247bbd0ecb8831272e41fe14b9ead82"
api_image=""
sync_image=""
output=""
allow_dirty=false
architectures_json='["linux/amd64","linux/arm64"]'
source_revision="$(git -C "${repo_root}" rev-parse HEAD)"

usage() {
  echo "usage: generate-release-manifest --api-image <digest-ref> --sync-image <digest-ref> --output <file> [--architectures linux/arm64|linux/amd64,linux/arm64] [--source-revision <sha>] [--allow-dirty]" >&2
}

while (($# > 0)); do
  case "$1" in
    --api-image) api_image="${2:-}"; shift 2 ;;
    --sync-image) sync_image="${2:-}"; shift 2 ;;
    --cloudflared-image) cloudflared_image="${2:-}"; shift 2 ;;
    --redis-image) redis_image="${2:-}"; shift 2 ;;
    --output) output="${2:-}"; shift 2 ;;
    --architectures)
      case "${2:-}" in
        linux/arm64) architectures_json='["linux/arm64"]' ;;
        linux/amd64,linux/arm64) architectures_json='["linux/amd64","linux/arm64"]' ;;
        *) echo "unsupported architecture set: ${2:-}" >&2; exit 2 ;;
      esac
      shift 2
      ;;
    --source-revision) source_revision="${2:-}"; shift 2 ;;
    --allow-dirty) allow_dirty=true; shift ;;
    *) usage; exit 2 ;;
  esac
done

command -v jq >/dev/null || { echo "jq is required" >&2; exit 1; }
if [[ ! "${source_revision}" =~ ^[0-9a-f]{40}$ ]]; then
  echo "source revision must be a 40-character lowercase Git SHA" >&2
  exit 1
fi
image_pattern='^[a-z0-9][a-z0-9._/-]*@sha256:[0-9a-f]{64}$'
for image in "${api_image}" "${sync_image}" "${cloudflared_image}" "${redis_image}"; do
  if [[ ! "${image}" =~ ${image_pattern} ]]; then
    echo "every image must be a fully qualified sha256 digest reference" >&2
    exit 1
  fi
done
if [[ -z "${output}" ]]; then
  usage
  exit 2
fi
if [[ -e "${output}" ]]; then
  echo "refusing to overwrite release manifest: ${output}" >&2
  exit 1
fi

source_tree_state=clean
if [[ -n "$(git -C "${repo_root}" status --porcelain)" ]]; then
  source_tree_state=dirty
  if [[ "${allow_dirty}" != true ]]; then
    echo "release manifests require a clean source tree; --allow-dirty is for local validation only" >&2
    exit 1
  fi
fi

sha256_file() {
  if command -v sha256sum >/dev/null; then
    sha256sum "$1" | awk '{print $1}'
  else
    shasum -a 256 "$1" | awk '{print $1}'
  fi
}

artifacts_json="$(
  find "${managed_root}" -type f \
    ! -path '*/generated/*' \
    ! -name '.DS_Store' \
    -print0 |
    sort -z |
    while IFS= read -r -d '' file; do
      relative="${file#"${managed_root}/"}"
      jq -cn --arg path "${relative}" --arg digest "$(sha256_file "${file}")" '{key:$path,value:$digest}'
    done |
    jq -s 'from_entries'
)"

generated_at="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
timestamp="$(date -u +%Y%m%dT%H%M%SZ)"
entropy="$(od -An -N4 -tx1 /dev/urandom | tr -d ' \n')"
release_id="managed-meeting-${timestamp}-${source_revision:0:12}-${entropy}"
mkdir -p "$(dirname "${output}")"
jq -n \
  --arg release_id "${release_id}" \
  --arg generated_at "${generated_at}" \
  --arg source_revision "${source_revision}" \
  --arg source_tree_state "${source_tree_state}" \
  --arg api_image "${api_image}" \
  --arg sync_image "${sync_image}" \
  --arg redis_image "${redis_image}" \
  --arg cloudflared_image "${cloudflared_image}" \
  --argjson architectures "${architectures_json}" \
  --argjson runtime_artifacts "${artifacts_json}" \
  '{
    schema_version: 1,
    release_id: $release_id,
    generated_at: $generated_at,
    source_revision: $source_revision,
    source_tree_state: $source_tree_state,
    architectures: $architectures,
    images: {
      api: $api_image,
      sync: $sync_image,
      redis: $redis_image,
      cloudflared: $cloudflared_image
    },
    database_compatibility: {
      engine: "postgresql",
      major: 18,
      minimum_migration: 20260713130000,
      maximum_migration: null
    },
    protocol_compatibility: {sync: 3},
    runtime_artifacts: $runtime_artifacts
  }' >"${output}"

echo "PASS release_manifest=${output} release_id=${release_id}"

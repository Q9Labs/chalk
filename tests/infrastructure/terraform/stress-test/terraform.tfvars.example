# Copy this file to terraform.tfvars and fill in values
# Do not commit secrets

aws_region = "us-east-1"

# Docker image for API (optional). Leave empty to use the ECR repo created by Terraform.
api_image = ""

# Aurora database credentials (use strong passwords in production)
db_username = "chalk_stress"
db_password = "CHANGE_ME_strong_password_here"

# Cloudflare RealtimeKit credentials
cloudflare_account_id = "YOUR_CLOUDFLARE_ACCOUNT_ID"
cloudflare_app_id = "YOUR_CLOUDFLARE_APP_ID"
cloudflare_api_token = "YOUR_CLOUDFLARE_API_TOKEN"

# Use real Cloudflare calls (false matches prod)
cloudflare_mock = false

# Sizing to match production-like t3.small profile
ecs_task_cpu = 256
ecs_task_memory = 512
ecs_desired_count = 1
db_instance_class = "db.serverless"
db_instance_count = 1
aurora_min_capacity = 0.5
aurora_max_capacity = 2
redis_node_type = "cache.t3.micro"
redis_num_cache_clusters = 2
redis_auth_token = ""
load_generator_instance_type = "t3.small"
load_generator_count = 3

{
  "printWidth": 300,
  "endOfLine": "lf",
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",
  "insertFinalNewline": true,
  "ignorePatterns": [
    "**/dist/**",
    "**/coverage/**",
    "**/.next/**",
    "**/.turbo/**",
    "**/tests/results/**",
    "**/*.snap",
    "**/routeTree.gen.ts",
    "apps/api/docs/api-design.html",
    "apps/api/docs/app.js",
    "apps/api/scratchpad/api-performance-*.html",
    "apps/api/scratchpad/api-performance-*.md",
    "apps/web/public/privacy/index.html",
    "apps/web/public/privacy-policy/index.html",
    "apps/web/public/terms/index.html",
    "contract/generated/frontend-proof.ir.json",
    "contract/generated/frontend-proof.report.md",
    "contract/schema/proof/invalid/**",
    "scratchpad/api-performance-*.html",
    "scratchpad/api-performance-*.md",
    "scratchpad/chalk-cost-calculator.html",
    "scratchpad/sync-codewalk.html"
  ]
}
